package com.example;

import static org.mockito.Mockito.*;
import static org.junit.Assert.*;

import org.junit.Before;
import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.Mock;
import org.mockito.junit.MockitoJUnitRunner;

import javax.persistence.EntityManager;
import javax.persistence.Query;
import java.sql.Clob;
import java.util.Date;
import java.util.List;
import java.util.ArrayList;
import java.util.stream.Stream;

@RunWith(MockitoJUnitRunner.class)
public class MyQueryJpaDaoTest {

    @Mock
    private EntityManager entityManager;

    @Mock
    private Query query;

    private MyQueryJpaDao dao;

    @Before
    public void setUp() {
        dao = new MyQueryJpaDao() {
            @Override
            protected EntityManager getEntityManager() {
                return entityManager;
            }
        };
        
        when(entityManager.createNativeQuery(anyString())).thenReturn(query);
        when(query.setParameter(anyString(), any())).thenReturn(query);
    }

    @Test
    public void testExecuteQueries() {
        // Setup test data
        Date testDate = new Date();
        Object[] reportData = new Object[]{"TestQuelle", "TestName", "TestRepR", testDate, testDate, testDate, testDate};
        Object[] xmlData = new Object[]{"TestCountry", "TestMRefId", null};

        // Mock getResultStream instead of getResultList
        when(query.getResultStream())
            .thenReturn(Stream.of(reportData))   // For first query (report data)
            .thenReturn(Stream.of(xmlData))      // For second query (XML data - DEA)
            .thenReturn(Stream.of(xmlData));     // For third query (XML data - DEI)

        // Execute test
        QueriesResults results = dao.executeQueries(1);

        // Debug print
        System.out.println("Report Data size: " + results.getReportData().size());
        System.out.println("XML Data size: " + results.getXmlFragmentData().size());

        // Basic verification
        assertNotNull(results);
        assertNotNull(results.getReportData());
        assertNotNull(results.getXmlFragmentData());

        // Verify correct methods were called
        verify(entityManager, times(3)).createNativeQuery(anyString());
        verify(query, times(3)).setParameter(anyString(), any());
        verify(query, times(3)).getResultStream();

        // Verify content if results are not empty
        if (!results.getReportData().isEmpty()) {
            QueriesResults.ReportData reportDataResult = results.getReportData().get(0);
            assertEquals("TestQuelle", reportDataResult.getQuelle());
            assertEquals("TestName", reportDataResult.getName());
            assertEquals("TestRepR", reportDataResult.getRepR());
            assertEquals(testDate, reportDataResult.getRepPerS());
        }

        if (!results.getXmlFragmentData().isEmpty()) {
            QueriesResults.XmlFragmentData xmlDataResult = results.getXmlFragmentData().get(0);
            assertEquals("TestCountry", xmlDataResult.getCountry());
            assertEquals("TestMRefId", xmlDataResult.getmRefId());
        }
    }
}
