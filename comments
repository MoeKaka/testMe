/**
 * Repräsentiert die Daten eines Reports mit verschiedenen Attributen und Zeitstempeln.
 * Diese statische innere Klasse ist Teil der QueriesResults-Klasse und enthält
 * detaillierte Informationen über einen einzelnen Report.
 * 
 * @author [Autor]
 * @version [Version]
 */
public static class RepData {
    
    /** Gibt an, ob Report-Daten existieren */
    private boolean isRepExist = false;
    
    /** Die Quelle des Reports */
    private String quelle;
    
    /** Der Name des Reports */
    private String mName = null;
    
    /** Die Report-Referenz */
    private String repR = null;
    
    /** Startzeitpunkt der Reportperiode */
    private Date repPerS = null;
    
    /** Endzeitpunkt der Reportperiode */
    private Date repPerE = null;
    
    /** Zeitpunkt des Reports */
    private Date repPer = null;
    
    /** Zeitstempel der Beschreibung */
    private Date desExTs = null;

    /**
     * Standardkonstruktor.
     * Initialisiert ein neues RepData-Objekt mit Standardwerten.
     */
    public RepData() {
    }

    /**
     * Konstruktor mit vollständiger Initialisierung aller Felder.
     *
     * @param quelle    Die Quelle des Reports
     * @param mName     Der Name des Reports
     * @param repR      Die Report-Referenz
     * @param repPerS   Startzeitpunkt der Reportperiode
     * @param repPerE   Endzeitpunkt der Reportperiode
     * @param repPer    Zeitpunkt des Reports
     * @param desExTs   Zeitstempel der Beschreibung
     */
    public RepData(String quelle, String mName, String repR, Date repPerS,
            Date repPerE, Date repPer, Date desExTs) {
        this.isRepExist = true;
        this.quelle = quelle;
        this.mName = mName;
        this.repR = repR;
        this.repPerS = repPerS;
        this.repPerE = repPerE;
        this.repPer = repPer;
        this.desExTs = desExTs;
    }
}
